# Copy to .env and fill in real values (never commit .env):
#   cp .env.example .env

# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=constant_co

PORT=3001

# --- Stripe (required for “Complete your payment” on appointment booking) ---
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Use sk_test_... and pk_test_... for development.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret (for payment_intent.succeeded after checkout). Optional until you configure webhooks.
# STRIPE_WEBHOOK_SECRET=

# --- Optional ---
# PUBLIC_SITE_URL=http://localhost:3001
# APPOINTMENT_TIMEZONE=Australia/Melbourne
# EMAIL_USER=
# EMAIL_PASS=
# OPENAI_API_KEY=
# DATABASE_URL=
